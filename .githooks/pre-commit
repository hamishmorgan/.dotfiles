#!/usr/bin/env bash
# Pre-commit hook: lint + secret scan
set -euo pipefail

# Lint (shellcheck, markdownlint, nixfmt, statix, deadnix)
if [[ -n "${IN_NIX_SHELL:-}" ]]; then
  make check
elif command -v nix >/dev/null 2>&1; then
  nix develop -c make check
fi

# Secret scan — prefer dev shell gitleaks, fall back to global
if command -v gitleaks >/dev/null 2>&1; then
  gitleaks git --pre-commit --staged --verbose
elif command -v nix >/dev/null 2>&1; then
  nix develop -c gitleaks git --pre-commit --staged --verbose
else
  printf "⚠ gitleaks not installed — skipping secret scan\n"
fi
