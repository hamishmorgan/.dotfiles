#!/usr/bin/env bash
# Pre-commit hook: scan staged changes for secrets using gitleaks
# Installed via: git config core.hooksPath .githooks

set -euo pipefail

if ! command -v gitleaks >/dev/null 2>&1; then
  printf "⚠ gitleaks not installed — skipping secret scan\n"
  printf "  Install: brew install gitleaks\n"
  exit 0
fi

gitleaks git --pre-commit --staged --verbose
