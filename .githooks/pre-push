#!/usr/bin/env bash
# Pre-push hook: scan all commits being pushed for secrets
# Installed via: git config core.hooksPath .githooks
set -euo pipefail

if command -v gitleaks >/dev/null 2>&1; then
  gitleaks git --verbose
elif command -v nix >/dev/null 2>&1; then
  nix develop -c gitleaks git --verbose
else
  printf "⚠ gitleaks not installed — skipping secret scan\n"
  printf "  Install: nix develop, or brew install gitleaks\n"
fi

# Warn if the last CI run failed
if command -v gh >/dev/null 2>&1; then
  last_conclusion=$(gh run list --limit 1 --json conclusion --jq '.[0].conclusion' 2>/dev/null || true)
  if [[ "$last_conclusion" == "failure" ]]; then
    printf "\n⚠ Last CI run failed. Pushing anyway — check CI after push.\n\n"
  fi
fi
