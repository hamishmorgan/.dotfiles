#!/usr/bin/env bash
# Pre-push hook: scan all commits being pushed for secrets
# Installed via: git config core.hooksPath .githooks
set -euo pipefail

if command -v gitleaks >/dev/null 2>&1; then
  gitleaks git --verbose
elif command -v nix >/dev/null 2>&1; then
  nix develop -c gitleaks git --verbose
else
  printf "⚠ gitleaks not installed — skipping secret scan\n"
  printf "  Install: nix develop, or brew install gitleaks\n"
fi

# Warn if the last CI run failed and show actionable details
if command -v gh >/dev/null 2>&1; then
  last_run=$(gh run list --limit 1 --json conclusion,url,name --jq '.[0]' 2>/dev/null || true)
  if [[ -n "$last_run" ]] && [[ "$(echo "$last_run" | jq -r '.conclusion')" == "failure" ]]; then
    url=$(echo "$last_run" | jq -r '.url')
    name=$(echo "$last_run" | jq -r '.name')
    printf "\n⚠ Last CI run failed: %s\n" "$name"
    printf "  %s\n\n" "$url"
    printf "  To inspect locally:\n"
    printf "    nix develop -c make check    # lint & format\n"
    printf "    gh run view --log-failed     # CI failure log\n\n"
  fi
fi
