{
  // ============================================================================
  // Cursor-Specific Settings
  // ============================================================================
  "cursor.composer.shouldAllowCustomModes": true,
  "cursor.composer.usageSummaryDisplay": "always",
  "cursor.diffs.useCharacterLevelDiffs": true,
  "cursor.windowSwitcher.sidebarHoverCollapsed": true,

  // ============================================================================
  // Editor - Global Settings
  // ============================================================================
  "editor.stickyTabStops": true,
  "editor.formatOnSave": true,
  "editor.minimap.enabled": true,
  "editor.minimap.showSlider": "always",
  "editor.bracketPairColorization.enabled": true,
  "editor.guides.bracketPairs": true,

  // File handling
  "files.autoSave": "onFocusChange",
  "files.trimTrailingWhitespace": true,
  "files.insertFinalNewline": true,

  // Breadcrumbs
  "breadcrumbs.enabled": true,

  // Search
  "search.exclude": {
    "**/node_modules": true,
    "**/bower_components": true,
    "**/.git": true,
    "**/vendor": true,
    "**/.bundle": true,
    "**/tmp": true,
    "**/log": true,
    "**/*.log": true
  },

  // ============================================================================
  // Editor Appearance & Workbench
  // ============================================================================
  "workbench.colorTheme": "Spinel",
  "workbench.iconTheme": "vscode-icons",
  "workbench.editor.wrapTabs": true,
  "window.density.editorTabHeight": "compact",

  // ============================================================================
  // Git & Version Control
  // ============================================================================
  "git.autofetch": true,
  "git.openRepositoryInParentFolders": "always",
  "diffEditor.ignoreTrimWhitespace": true,
  "gitlens.rebaseEditor.ordering": "asc",

  // GitHub Pull Requests
  "githubPullRequests.pullBranch": "never",
  "githubPullRequests.terminalLinksHandler": "github",

  // ============================================================================
  // Terminal
  // ============================================================================
  "terminal.integrated.scrollback": 100000,
  "terminal.integrated.enableImages": true,

  // Terminal customizations (more subtle search highlighting)
  "workbench.colorCustomizations": {
    "terminal.findMatchBackground": "#ffcc0060",
    "terminal.findMatchBorder": "#ffcc00",
    "terminal.findMatchHighlightBackground": "#ffcc0040",
    "terminal.findMatchHighlightBorder": "#ffcc0080",
    "terminalOverviewRuler.findMatchForeground": "#ffcc00"
  },

  // ============================================================================
  // File Explorer
  // ============================================================================
  "explorer.fileNesting.enabled": true,
  "explorer.fileNesting.expand": false,
  "explorer.fileNesting.patterns": {
    // TypeScript/JavaScript
    "*.ts": "${capture}.js, ${capture}.d.ts",
    "*.js": "${capture}.js.map, ${capture}.min.js, ${capture}.d.ts",
    "*.jsx": "${capture}.js",
    "*.tsx": "${capture}.ts",
    "tsconfig.json": "tsconfig.*.json",
    
    // Package managers
    "package.json": "package-lock.json, yarn.lock, pnpm-lock.yaml, bun.lockb",
    "Gemfile": "Gemfile.lock",
    
    // Ruby
    "*.rb": "${capture}_test.rb, ${capture}_spec.rb",
    
    // Environment files
    ".env": ".env.*, .envrc",
    
    // Documentation
    "README.md": "README*, CHANGELOG*, CONTRIBUTING*, LICENSE*",
    
    // Database files
    "*.sqlite": "${capture}.${extname}-*",
    "*.db": "${capture}.${extname}-*",
    "*.sqlite3": "${capture}.${extname}-*",
    "*.db3": "${capture}.${extname}-*",
    "*.sdb": "${capture}.${extname}-*",
    "*.s3db": "${capture}.${extname}-*"
  },

  // ============================================================================
  // Language-Specific Settings
  // ============================================================================

  // Ruby
  "[ruby]": {
    "editor.defaultFormatter": "Shopify.ruby-lsp",
    "editor.formatOnSave": true,
    "editor.formatOnType": true,
    "editor.tabSize": 2,
    "editor.insertSpaces": true,
    "files.trimTrailingWhitespace": true,
    "files.insertFinalNewline": true,
    "files.trimFinalNewlines": true,
    "editor.rulers": [120],
    "editor.semanticHighlighting.enabled": true,
    "editor.quickSuggestions": {
      "comments": true
    },
    "editor.suggest.showWords": false
  },

  // JSON
  "[json]": {
    "editor.defaultFormatter": "vscode.json-language-features"
  },

  // Docker Compose
  "[dockercompose]": {
    "editor.insertSpaces": true,
    "editor.tabSize": 2,
    "editor.autoIndent": "advanced",
    "editor.defaultFormatter": "redhat.vscode-yaml"
  },

  // GitHub Actions
  "[github-actions-workflow]": {
    "editor.defaultFormatter": "redhat.vscode-yaml"
  },

  // YAML
  "[yaml]": {
    "editor.insertSpaces": true,
    "editor.tabSize": 2,
    "editor.autoIndent": "advanced"
  },

  // Markdown
  "[markdown]": {
    "editor.wordWrap": "on",
    "editor.quickSuggestions": {
      "comments": "off",
      "strings": "off",
      "other": "off"
    }
  },

  // ============================================================================
  // Extensions
  // ============================================================================

  // Ruby LSP
  "rubyLsp.featureFlags": {
    "tapiocaAddon": false
  },

  // Sorbet
  "sorbet.highlightUntyped": "everywhere",

  // Code Spell Checker
  "cSpell.enableFiletypes": ["ruby"],
  "cSpell.userWords": [
    "autofetch",
    "cadetgear",
    "Datetime",
    "fulfillable",
    "Geolocator",
    "importmap",
    "interruptible",
    "isospin",
    "Jsonify",
    "kamal",
    "killswitch",
    "klass",
    "merch",
    "metafield",
    "metafields",
    "normalised",
    "Omakase",
    "preorder",
    "propshaft",
    "regexes",
    "rubocop",
    "scrollback",
    "Shipify",
    "Smush",
    "snowdevil",
    "snowdevils",
    "statsd",
    "unfulfill",
    "unranked",
    "unsplit",
    "unstock",
    "UNSUBMITTED",
    "xlarge",
    "Xpresspost",
    "zoneinfo"
  ],

  // VS Icons
  "vsicons.dontShowNewVersionMessage": true,

  // Red Hat telemetry
  "redhat.telemetry.enabled": false,

  // JavaScript/TypeScript
  "javascript.updateImportsOnFileMove.enabled": "always",
  "typescript.updateImportsOnFileMove.enabled": "always",

  // Comment highlighting (TODO, FIXME, etc) - more subtle colors with transparency
  "highlight.regexes": {
    "((?:<!-- *)?(?:#|// @|//|./\\*+|<!--|--|\\* @|{!|{{!--|{{!) *TODO(?:\\s*\\([^)]+\\))?:?)((?!\\w)(?: *-->| *\\*/| *!}| *--}}| *}}|(?= *(?:[^:]//|/\\*+|<!--|@|--|{!|{{!--|{{!))|(?: +[^\\n@]*?)(?= *(?:[^:]//|/\\*+|<!--|@|--(?!>)|{!|{{!--|{{!))|(?: +[^@\\n]+)?))": {
      "filterFileRegex": ".*(?<!CHANGELOG.md)$",
      "decorations": [
        {
          "overviewRulerColor": "#ffcc00",
          "backgroundColor": "#ffcc0040",
          "color": "#ffcc00",
          "fontWeight": "bold"
        },
        {
          "backgroundColor": "#ffcc0020"
        }
      ]
    },
    "((?:<!-- *)?(?:#|// @|//|./\\*+|<!--|--|\\* @|{!|{{!--|{{!) *(?:FIXME|FIX|BUG|UGLY|DEBUG|HACK)(?:\\s*\\([^)]+\\))?:?)((?!\\w)(?: *-->| *\\*/| *!}| *--}}| *}}|(?= *(?:[^:]//|/\\*+|<!--|@|--|{!|{{!--|{{!))|(?: +[^\\n@]*?)(?= *(?:[^:]//|/\\*+|<!--|@|--(?!>)|{!|{{!--|{{!))|(?: +[^@\\n]+)?))": {
      "filterFileRegex": ".*(?<!CHANGELOG.md)$",
      "decorations": [
        {
          "overviewRulerColor": "#ff6b6b",
          "backgroundColor": "#ff6b6b40",
          "color": "#ff6b6b",
          "fontWeight": "bold"
        },
        {
          "backgroundColor": "#ff6b6b20"
        }
      ]
    },
    "((?:<!-- *)?(?:#|// @|//|./\\*+|<!--|--|\\* @|{!|{{!--|{{!) *(?:REVIEW|OPTIMIZE|TSC)(?:\\s*\\([^)]+\\))?:?)((?!\\w)(?: *-->| *\\*/| *!}| *--}}| *}}|(?= *(?:[^:]//|/\\*+|<!--|@|--|{!|{{!--|{{!))|(?: +[^\\n@]*?)(?= *(?:[^:]//|/\\*+|<!--|@|--(?!>)|{!|{{!--|{{!))|(?: +[^@\\n]+)?))": {
      "filterFileRegex": ".*(?<!CHANGELOG.md)$",
      "decorations": [
        {
          "overviewRulerColor": "#4ecdc4",
          "backgroundColor": "#4ecdc440",
          "color": "#4ecdc4",
          "fontWeight": "bold"
        },
        {
          "backgroundColor": "#4ecdc420"
        }
      ]
    },
    "((?:<!-- *)?(?:#|// @|//|./\\*+|<!--|--|\\* @|{!|{{!--|{{!) *(?:IDEA)(?:\\s*\\([^)]+\\))?:?)((?!\\w)(?: *-->| *\\*/| *!}| *--}}| *}}|(?= *(?:[^:]//|/\\*+|<!--|@|--|{!|{{!--|{{!))|(?: +[^\\n@]*?)(?= *(?:[^:]//|/\\*+|<!--|@|--(?!>)|{!|{{!--|{{!))|(?: +[^@\\n]+)?))": {
      "filterFileRegex": ".*(?<!CHANGELOG.md)$",
      "decorations": [
        {
          "overviewRulerColor": "#c678dd",
          "backgroundColor": "#c678dd40",
          "color": "#c678dd",
          "fontWeight": "bold"
        },
        {
          "backgroundColor": "#c678dd20"
        }
      ]
    }
  },

  // ============================================================================
  // Remote Development
  // ============================================================================
  "remote.SSH.connectTimeout": 150
}
