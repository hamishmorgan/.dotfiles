# Shared shell aliases (bash + zsh)
{
  ".." = "cd ..";
  "..." = "cd ../..";
  "...." = "cd ../../..";
  c = "clear";

  # Git
  g = "git";
  gs = "git status";
  ga = "git add";
  gc = "git commit";
  gp = "git push";
  gl = "git pull";
  gd = "git diff";
  glog = "git log --oneline --graph --decorate";
  gwt = "git worktree";
  gwta = "git worktree add";
  gwtl = "git worktree list";
  gwtr = "git worktree remove";
}
